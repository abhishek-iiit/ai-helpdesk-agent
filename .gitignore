# ============================================================
# AI IT Helpdesk Agent — .gitignore
# ============================================================

# Environment & Secrets — NEVER commit these
.env
*.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual Environments
.venv/
venv/
env/
ENV/

# Distribution / Packaging
dist/
build/
*.egg-info/
*.egg
site-packages/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
*.log
logs/

# LangSmith / LangFuse local cache
.langsmith/
.langfuse/
